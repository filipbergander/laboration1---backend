<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Visa kurser</title>
</head>

<body>
    <div id="message"></div>
    <header>
        <nav>
            <ul>
                <li><a href="/" class="current-page">Hem</a></li>
                <li><a href="/about">Om</a></li>
                <li><a href="/newcourse">Lägg till kurs</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <h1>Kurser</h1>
        <table>
            <tr>
                <th>KursID</th>
                <th>Kurskod</th>
                <th>Kursnamn</th>
                <th>Progression</th>
                <th>Kursplan</th>
                <th>Skapad</th>
            </tr>
            <tbody id="table-body">
                <% courses.forEach(course=> { %>
                    <tr>
                        <td>
                            <%= course.id %>
                        </td>
                        <td>
                            <%= course.code %>
                        </td>
                        <td>
                            <%= course.name %>
                        </td>
                        <td>
                            <%= course.progression %>
                        </td>
                        <td>
                            <%= course.syllabus %>
                        </td>
                        <td>
                            <%= course.posted%>
                        </td>
                        <td>
                            <form method="post" action="/delete">
                                <label for="delete">Ta bort kurs</label>
                                <input type="submit" id="delete" value="<%=course.id%>">
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </main>
</body>

</html>
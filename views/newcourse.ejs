<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Lägg till kurs</title>
</head>

<body>
    <main>
        <form id="course-form">
            <label for="code">Kurskod</label>
            <input type="text" name="code" id="code">
            <br>
            <label for="coursename">Kursnamn</label>
            <input type="text" name="coursename" id="coursename">
            <br>
            <label for="progression">Progression</label>
            <input type="text" name="progression" id="progression">
            <br>
            <label for="syllabus">Kursplan</label>
            <input type="text" name="syllabus" id="syllabus">
            <br>
            <button type="submit" id="newcourse-button">Lägg till kurs</button>
        </form>
    </main>
</body>

</html>
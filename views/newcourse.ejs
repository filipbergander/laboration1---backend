<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Lägg till kurs</title>
</head>

<body>
    <div id="message"></div>
    <nav>
        <ul>
            <li><a href="/">Hem</a></li>
            <li><a href="/about">Om</a></li>
            <li><a href="/newcourse">Lägg till kurs</a></li>
        </ul>
    </nav>
    <main>
        <h1>Lägg till kurs</h1>
        <p id="err-message"></p>
        <form method="post" action="/" id="course-form">
            <label for="code">Kurskod</label>
            <input type="text" name="code" id="code" required>
            <br>
            <label for="name">Kursnamn</label>
            <input type="text" name="name" id="name" required>
            <br>
            <label for="progression">Progression</label>
            <input type="text" name="progression" id="progression" required>
            <br>
            <label for="syllabus">Kursplan</label>
            <input type="text" name="syllabus" id="syllabus" required>
            <br>
            <input type="submit" id="newcourse-button" value="Lägg till kurs">
        </form>
    </main>
</body>

</html>